# ASI 360 Agency Environment Variables
# Copy this to .env and fill in your actual values

# Client 1 Database Credentials
CLIENT1_DB_PASSWORD=generate_secure_password_here
CLIENT1_ROOT_PASSWORD=generate_secure_password_here

# JCCIX (Hurricane Relief) Database Credentials
JCCIX_DB_PASSWORD=generate_secure_password_here
JCCIX_ROOT_PASSWORD=generate_secure_password_here

# Supabase (for agency CMS & automation)
SUPABASE_URL=https://jvjlhxodmbkodzmggwpu.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Claude API (for AI website generation)
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Backup Configuration (optional)
BACKUP_S3_BUCKET=asi360-client-backups
AWS_ACCESS_KEY=your_aws_key_here
AWS_SECRET_KEY=your_aws_secret_here

# Email for Let's Encrypt SSL certificates
LETSENCRYPT_EMAIL=admin@asi360.com
