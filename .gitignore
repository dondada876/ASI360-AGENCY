# ASI 360 Agency - Git Ignore Rules

# Environment & Secrets
.env
*.env
!.env.example

# Docker volumes & data
letsencrypt/
backups/
client-configs/*/passwords.txt

# Astra Pro plugins (proprietary)
astra-pro-plugins/

# Client data directories
*_wp_data/
*_mysql_data/

# Logs
*.log
nohup.out

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
tmp/
temp/
*.tmp

# WordPress cache
wp-content/cache/
wp-content/uploads/wc-logs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# API Keys & Credentials (extra safety)
*credentials*.json
*secrets*.json
*api*keys*.txt
*.pem
*.key
*.cert

# Database dumps
*.sql
*.sqlite
*.db
