# Agency Portal Environment Variables - Security Configuration

# =============================================================================
# SECURITY FEATURE FLAGS
# =============================================================================
# Set to 'true' to enable each security feature independently

# JWT Authentication (login/logout/tokens)
ENABLE_AUTHENTICATION=false

# Rate limiting (prevent API abuse)
ENABLE_RATE_LIMITING=false

# Input validation (XSS, SQL injection protection)
ENABLE_INPUT_VALIDATION=false

# CORS protection (restrict origins)
ENABLE_CORS_PROTECTION=false

# Security headers (Helmet.js)
ENABLE_SECURITY_HEADERS=false

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Main JWT secret for access tokens
JWT_SECRET=GENERATE_NEW_SECRET_FOR_PRODUCTION

# Access token expiration (e.g., 1h, 24h, 7d)
JWT_EXPIRES_IN=24h

# Refresh token secret (different from main secret)
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_SECRET_FOR_REFRESH

# Refresh token expiration
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================

# Time window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Comma-separated list of allowed origins
# Example: https://portal.asi360.com,https://monitor.asi360.com
ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# ADMIN USER CONFIGURATION
# =============================================================================
# Used by setup-admin.js script to create first admin user

ADMIN_EMAIL=admin@asi360.com
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD_123!

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

NODE_ENV=production
PORT=3000

# Supabase configuration (from root .env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Anthropic API configuration
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. GENERATE JWT SECRETS (IMPORTANT!)
#    Run these commands and replace the values above:
#
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# 2. SET ADMIN PASSWORD
#    Change ADMIN_PASSWORD to a secure password
#
# 3. ENABLE FEATURES GRADUALLY
#    Start with:
#    - ENABLE_SECURITY_HEADERS=true
#    - ENABLE_CORS_PROTECTION=true
#    Then add:
#    - ENABLE_RATE_LIMITING=true
#    - ENABLE_INPUT_VALIDATION=true
#    Finally:
#    - ENABLE_AUTHENTICATION=true
#
# 4. CREATE ADMIN USER
#    npm run setup-admin
#
# 5. TEST
#    npm start
#    curl http://localhost:3000/api/health
#
# =============================================================================
